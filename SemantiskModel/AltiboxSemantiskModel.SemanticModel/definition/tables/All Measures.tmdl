	measure 'Antal Annulleringer ÅTD' =
			
			CALCULATE (
			    DISTINCTCOUNT ( 'status'[KundeNO] ),
			
			    // Base logic
			    KEEPFILTERS ( 'status'[NySalg] = "true" ),
			    KEEPFILTERS ( 'status'[Kunde_Status] = "Churned" ),
			    KEEPFILTERS ( 'status'[endDate] <= 'status'[startDate] ),
			
			    // YTD: from January 1st this year to today
			    KEEPFILTERS (
			        'status'[endDate] >= DATE ( YEAR ( TODAY() ), 1, 1 )
			            && 'status'[endDate] <= TODAY()
			       )
			)
		formatString: 0
		displayFolder: CRM FORÆLDET
		lineageTag: b422ce9b-a26b-4a6f-8fd4-fd63c0bee2d5

		changedProperty = Name

		changedProperty = DisplayFolder

