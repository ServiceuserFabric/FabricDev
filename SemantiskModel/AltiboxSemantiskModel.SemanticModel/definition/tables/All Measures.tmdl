	measure Pålogningstid =
			
			SUMX(
			    FILTER(
			        agent_events,
			        agent_events[event_type] = "i"
			            && NOT ISBLANK(agent_events[agent_id])
			            && NOT ISBLANK(agent_events[dte_start])
			    ),
			    VAR Agent  = agent_events[agent_id]
			    VAR InTime = agent_events[dte_start]
			
			    -- Find next sign-out for same agent, ignoring the date filter (Calendar)
			    VAR OutTime =
			        MINX(
			            FILTER(
			                CALCULATETABLE(agent_events, REMOVEFILTERS('Calendar')),
			                agent_events[agent_id] = Agent
			                    && agent_events[event_type] = "o"
			                    && agent_events[dte_start] > InTime
			            ),
			            agent_events[dte_start]
			        )
			    RETURN
			        IF(
			            NOT ISBLANK(OutTime),
			            (OutTime - InTime) * 86400,   -- seconds
			            BLANK()
			        )
			)
		displayFolder: Puzzel
		lineageTag: 47697929-9312-4c24-8e88-5a05860a3178

		changedProperty = DisplayFolder

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

