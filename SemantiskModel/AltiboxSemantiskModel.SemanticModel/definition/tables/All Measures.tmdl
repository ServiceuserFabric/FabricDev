	/// En kopi af Antal Kunder %Calendar for at kunne sammenligne i går med i dag til betinget formatering.
	measure 'Antal Kunder %Calender Last Month' =
			
			VAR d = EOMONTH ( [AsOf Date], -1 )
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			    REMOVEFILTERS( 'Calendar' ),
			    ProductHistory[Kunde_Status] = "Aktive",
			    ProductHistory[Produkt_Status] = "I brug",
			    ProductHistory[FromDate] <= d,
			    ProductHistory[ToDate] > d
			)
		formatString: 0
		displayFolder: CRM (ProductHistory) AKTIVE
		lineageTag: 5a160fe4-e258-4367-bad1-dd9769c1acce

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = Description

	measure 'Antal Kunder Color' =
			
			VAR TodayVal = [Antal Kunder %Calendar]
			VAR YestVal  = [Antal Kunder %Calender Last Month]
			RETURN
			IF (
			    ISBLANK(TodayVal) || ISBLANK(YestVal),
			    BLANK(),
			    IF ( YestVal > TodayVal, "#D13438", "#107C10" )
			)
		displayFolder: CRM (ProductHistory) AKTIVE
		lineageTag: 227599ca-1fd1-4353-be03-2eaa8a86119a

		changedProperty = DisplayFolder

		changedProperty = Name

	/// Denne measure bruger primært forbindelsen til kalenderen Calender Comparison Periods, for at kunne opdele measure i flere perioder. Den baserer sig på den primære measure Antal Kunder
	measure 'Aktive Kunder Sammenligningsperioder' =
			
			VAR d0 =
			    [AsOf Date]
			
			VAR IsPrimo =
			    SELECTEDVALUE ( 'Calendar Comparison Periods'[IsPrimo], 0 )
			
			VAR OffsetM =
			    SELECTEDVALUE ( 'Calendar Comparison Periods'[OffsetMonths], 0 )
			
			VAR TargetDate =
			    IF (
			        IsPrimo = 1,
			        DATE ( YEAR ( d0 ), 1, 1 ),          -- Primo i samme år som AsOf
			        EOMONTH ( d0, OffsetM )               -- Månedsskift-baseret
			    )
			
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			    REMOVEFILTERS ( 'Calendar' ),
			    ProductHistory[Kunde_Status] = "Aktive",
			    ProductHistory[Produkt_Status] = "I brug",
			    ProductHistory[FromDate] <= TargetDate,
			    ProductHistory[ToDate] > TargetDate
			)
		formatString: 0
		displayFolder: CRM (ProductHistory) AKTIVE
		lineageTag: ab38cb76-d52b-4c1c-836f-b10a58723b32

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = Description

