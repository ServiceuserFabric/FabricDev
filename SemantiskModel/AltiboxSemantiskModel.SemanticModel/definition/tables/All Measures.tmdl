	measure 'AsOf Date Comparison' =
			
			VAR SelectedMonthStart =
			    SELECTEDVALUE ( 'Calendar Comparison'[MonthStart Comparison] )
			
			VAR CurrentMonthStart =
			    DATE ( YEAR ( TODAY() ), MONTH ( TODAY() ), 1 )
			
			VAR MonthToUse =
			    COALESCE ( SelectedMonthStart, CurrentMonthStart )
			
			RETURN
			IF (
			    MonthToUse = CurrentMonthStart,
			    TODAY (),
			    EOMONTH ( MonthToUse, 0 )
			)
		formatString: General Date
