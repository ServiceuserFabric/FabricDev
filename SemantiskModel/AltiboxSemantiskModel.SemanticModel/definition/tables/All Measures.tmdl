	measure 'Antal Kunder Annulleringer Current Produktvalg' =
			
			VAR Cat = SELECTEDVALUE ( Produktvalg[Kategori], "Internet" )
			RETURN
			CALCULATE (
			    [Antal  Kunder Annulleringer Current],
			    FILTER (
			        Product_config,
			        SWITCH (
			            Cat,
			
			            "Internet",
			                Product_config[HovedProduktGruppe] = "Internet"
			                    && Product_config[productGroup] <> "Migrering",
			
			            "TV",
			                Product_config[HovedProduktGruppe] = "TV",
			
			            "TV Streaming",
			                Product_config[HovedProduktGruppe] = "Streaming",
			
			            "TV Tilvalg",
			                Product_config[HovedProduktGruppe] = "TV Tilvalg",
			
			            "VOIP",
			                Product_config[HovedProduktGruppe] = "VOIP",
			
			            "Tilbehør",
			                Product_config[HovedProduktGruppe] = "Antivirus"
			                    || Product_config[HovedProduktGruppe] = "Fast IP"
			                    || (
			                        Product_config[HovedProduktGruppe] = "Internet Tilvalg"
			                        && Product_config[productGroup] = "IP"
			                    ),
			            TRUE
			        )
			    )
			)
		formatString: #,0
