	measure 'Gennemsnitlig efterbehandlingstid per opkald (mm:ss)' =
			
			VAR TotalSpeakSec =
			    CALCULATE(
			        SUM(call_events[wrap_up_sec]),
			        KEEPFILTERS( call_events[event_type] = "c" ),
			        KEEPFILTERS( call_events[result_code] IN { "k" } ),
			        KEEPFILTERS( call_events[media_type_id] = 1 ),
			        KEEPFILTERS( call_events[queue_key] <> "__CALLOUT__" )
			    )
			VAR CallCount =
			    CALCULATE(
			        DISTINCTCOUNT(call_events[call_id]),
			        KEEPFILTERS( call_events[event_type] = "c" ),
			        KEEPFILTERS( call_events[result_code] IN { "k" } ),
			        KEEPFILTERS( call_events[media_type_id] = 1 ),
			        KEEPFILTERS( call_events[queue_key] <> "__CALLOUT__" )
			    )
			VAR AvgSec = DIVIDE(TotalSpeakSec, CallCount)
			VAR Minutes = INT( AvgSec / 60 )
			VAR Seconds = INT( MOD( AvgSec, 60 ) )
			RETURN
			    FORMAT( Minutes, "0" ) & ":" & FORMAT( Seconds, "00" )
		displayFolder: Puzzel
		lineageTag: ba15151f-1ae8-441d-b239-37225d5f70e2

		changedProperty = DisplayFolder

		changedProperty = Name

	measure 'Gennemsnitlig taletid per opkald (mm:ss)' =
			
			VAR TotalSpeakSec =
			    CALCULATE(
			        SUM(call_events[duration_speak_sec]),
			        KEEPFILTERS( call_events[event_type] = "c" ),
			        KEEPFILTERS( call_events[result_code] IN { "k" } ),
			        KEEPFILTERS( call_events[media_type_id] = 1 ),
			        KEEPFILTERS( call_events[queue_key] <> "__CALLOUT__" )
			    )
			VAR CallCount =
			    CALCULATE(
			        DISTINCTCOUNT(call_events[call_id]),
			        KEEPFILTERS( call_events[event_type] = "c" ),
			        KEEPFILTERS( call_events[result_code] IN { "k" } ),
			        KEEPFILTERS( call_events[media_type_id] = 1 ),
			        KEEPFILTERS( call_events[queue_key] <> "__CALLOUT__" )
			    )
			VAR AvgSec = DIVIDE(TotalSpeakSec, CallCount)
			VAR Minutes = INT( AvgSec / 60 )
			VAR Seconds = INT( MOD( AvgSec, 60 ) )
			RETURN
			    FORMAT( Minutes, "0" ) & ":" & FORMAT( Seconds, "00" )
