	measure 'Antal Kunder %Calendar' = ```
			
			VAR d = [AsOf Date]
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			    REMOVEFILTERS ( 'Calendar' ),
			    REMOVEFILTERS ( 'Calendar Comparison' ),
			    ProductHistory[Kunde_Status] = "Aktive",
			    ProductHistory[Produkt_Status] = "I brug",
			    ProductHistory[FromDate] <= d,
			    ProductHistory[ToDate] > d)
			
			```
		formatString: #,0
		displayFolder: CRM (ProductHistory) AKTIVE
		lineageTag: 4f6f05f5-d3c3-4fd1-bec2-b723c6865642

		changedProperty = Name

		changedProperty = DisplayFolder

		changedProperty = FormatString

	/// Anvendes til at vise antallet af kunder på en fleksibelt valgt dato
	measure 'AsOf Date' =
			
			VAR SelectedMonthStart =
			    SELECTEDVALUE ( 'Calendar'[MonthStart] )
			
			VAR CurrentMonthStart =
			    DATE ( YEAR ( TODAY() ), MONTH ( TODAY() ), 1 )
			
			VAR MonthToUse =
			    COALESCE ( SelectedMonthStart, CurrentMonthStart )
			
			RETURN
			IF (
			    MonthToUse = CurrentMonthStart,
			    TODAY (),
			    EOMONTH ( MonthToUse, 0 )
			)
		formatString: General Date
		isHidden
		displayFolder: Date
		lineageTag: aa4433a5-d5c0-41bc-bf1f-50531062bd1c

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = Description

		changedProperty = IsHidden

	measure 'Aktive tv-andel NY' =
			
			VAR d = [AsOf Date]
			VAR TvCustomers =
			    CALCULATE (
			        DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			        Product_config[ProductGroup] = "TV - Pakker",
			        REMOVEFILTERS ( 'Calendar' ),
			        ProductHistory[Kunde_Status] = "Aktive",
			        ProductHistory[FromDate] <= d,
			        COALESCE ( ProductHistory[ToDate], DATE ( 9999, 12, 31 ) ) >= d
			    )
			VAR InternetCustomers =
			    CALCULATE (
			        DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			        Product_config[HovedProduktGruppe] = "Internet",
			        REMOVEFILTERS ( 'Calendar' ),
			        ProductHistory[Kunde_Status] = "Aktive",
			        ProductHistory[FromDate] <= d,
			        COALESCE ( ProductHistory[ToDate], DATE ( 9999, 12, 31 ) ) >= d
			    )
			RETURN
			DIVIDE ( TvCustomers, InternetCustomers )
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: CRM (ProductHistory) AKTIVE
		lineageTag: 1072e346-56ed-4306-b10c-a6c0cdf207f7

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = FormatString

	measure 'Antal Kunder (Daglig udvikling)' =
			
			VAR d =
			    MAX ( 'Calendar'[Date] )   -- one date per day on the axis
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			    REMOVEFILTERS ( 'Calendar' ),
			    ProductHistory[Kunde_Status] = "Aktive",
			    ProductHistory[Produkt_Status] = "I brug",
			    ProductHistory[FromDate] <= d,
			    COALESCE ( ProductHistory[ToDate], DATE ( 9999, 12, 31 ) ) >= d
			)
		formatString: 0
		displayFolder: CRM (ProductHistory) AKTIVE
		lineageTag: 1d024b64-f9de-4c5b-ace2-b205aa0b5bad

		changedProperty = DisplayFolder

		changedProperty = Name

	measure 'Antal Nysalg Kunder %Calendar' =
			
			VAR _Today = TODAY()
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			    -- use orderedDate relationship for the calculation
			    USERELATIONSHIP ( 'Calendar'[Date], ProductHistory[orderedDate] ),
			
			    ProductHistory[NySalg] = "1",
			    ProductHistory[FromDate] <= _Today,
			    COALESCE ( ProductHistory[ToDate], DATE ( 9999, 12, 31 ) ) > _Today,
			    Customer[ca_created] = ""
			)
		formatString: 0
		displayFolder: CRM (ProductHistory) NYSALG
		lineageTag: 0728bd42-4256-4937-93b7-d63bb7a5cb6d

		changedProperty = DisplayFolder

		changedProperty = Name

	measure 'Antal Nysalg Nye Kunder Current' =
			
			VAR StartDate = MIN ( 'Calendar'[Date] )
			VAR EndDate   = MAX ( 'Calendar'[Date] )
			VAR AsOf      = EndDate
			RETURN
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			
			
			    REMOVEFILTERS ( 'Calendar Comparison' ),
			
			
			    REMOVEFILTERS ( ProductHistory[FromDate] ),
			
			
			    USERELATIONSHIP ( 'Calendar'[Date], ProductHistory[orderedDate] ),
			
			
			    ProductHistory[orderedDate] >= StartDate,
			    ProductHistory[orderedDate] <= EndDate,
			
			
			    ProductHistory[FromDate] <= AsOf,
			    COALESCE ( ProductHistory[ToDate], DATE ( 9999, 12, 31 ) ) >= AsOf,
			
			    ProductHistory[NySalg] = "1",
			    Customer[ca_created] = ""
			)
		formatString: #,0
		displayFolder: CRM (ProductHistory) NYSALG
		lineageTag: 3d8f7ddb-ea8f-4714-95f1-5e64d6b4b50c

		changedProperty = DisplayFolder

		changedProperty = Name

		changedProperty = FormatString

	/// Måltallet beregner antal nysalg 
	measure 'Antal Nysalg Nye Kunder Comparison' = ```
			
			-- Virker med Month Compare Filter
			VAR StartDate = MIN('Calendar Comparison'[Date])
			VAR EndDate   = MAX('Calendar Comparison'[Date])
			VAR AsOf      = EndDate
			RETURN
