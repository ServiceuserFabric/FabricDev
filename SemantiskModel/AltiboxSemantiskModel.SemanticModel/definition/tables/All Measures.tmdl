	measure 'Antal Nysalg Kunder Medarbejdere TV %Calendar' =
			
			CALCULATE (
			    DISTINCTCOUNT ( ProductHistory[KundeNO] ),
			    ProductHistory[NySalg] = "1",
			    ProductHistory[FromDate] <= TODAY(),
			    Product_config[ProductMainGroup] in {"TV", "TVSA"},
			    NOT(ISBLANK(MicrosoftAD_users[jobTitle])) ,
			    COALESCE ( ProductHistory[ToDate], DATE ( 9999, 12, 31 ) ) > TODAY(),
			    Customer[ca_created] = "",
			    USERELATIONSHIP ( ProductHistory[OrderedDate], 'Calendar'[Date] )
			)
		formatString: 0
		displayFolder: CRM (ProductHistory) NYSALG
		lineageTag: 8e62f09f-69bb-4410-a1e9-065ca1548530

		changedProperty = DisplayFolder

		changedProperty = Name

