	measure 'AST per opkald (mm:ss)' =
			
			VAR AvgSeconds =
			    COALESCE (
			        AVERAGE ( call_events[duration_speak_sec] ),
			        0
			    )
			VAR Minutes =
			    INT ( AvgSeconds / 60 )
			VAR Seconds =
			    MOD ( ROUND ( AvgSeconds, 0 ), 60 )
			RETURN
			    FORMAT ( Minutes, "00" ) & ":" & FORMAT ( Seconds, "00" )
		displayFolder: Puzzel
		lineageTag: 8495b1a9-981b-4cd2-a857-0e359769091f

		changedProperty = DisplayFolder

		changedProperty = Name

