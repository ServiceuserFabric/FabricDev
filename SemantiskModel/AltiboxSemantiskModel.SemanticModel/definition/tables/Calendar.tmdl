		lineageTag: 12f19133-6161-4450-8508-eea68ae9f964
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Aktuel dato (Filter)' = if('Calendar'[Date] = TODAY() - 1, 1, 0)
		formatString: 0
		lineageTag: 7a0379ba-d791-40fa-b317-87e2b13a4bdc
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Formål til filterudsnit
	column MonthStart =
			
			DATE ( YEAR ( 'Calendar'[Date] ), MONTH ( 'Calendar'[Date] ), 1 )
		formatString: General Date
		displayFolder: Filterformål
		lineageTag: 22126b30-8636-4ef2-8ff1-96b297443358
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MonthKey =
			
			YEAR ( 'Calendar'[Date] ) * 100 + MONTH ( 'Calendar'[Date] )
		formatString: 0
		displayFolder: Filterformål
		lineageTag: ae1838bc-9f08-4533-af22-043adf4375e7
		summarizeBy: count

		annotation SummarizationSetBy = Automatic

	/// Bruges til at definere indeværende måned i slicer
	column ÅrMåned_Default =
			
			VAR CurrentMonthStart = DATE ( YEAR ( TODAY() ), MONTH ( TODAY() ), 1 )
			RETURN
			IF (
			    'Calendar'[MonthStart] = CurrentMonthStart,
			    "Indeværende måned",
			    'Calendar'[ÅrMåned]
			)
		displayFolder: Filterformål
		lineageTag: b8657b41-bacf-46bb-959b-49d361b9e4e2
		summarizeBy: none
		sortByColumn: ÅrMåned

		annotation SummarizationSetBy = Automatic

	column MonthEnd = EOMONTH('Calendar'[MonthStart],0)
		formatString: General Date
		displayFolder: Filterformål
		lineageTag: 40cda7a9-3d11-4ef9-8288-7cda74368b89
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Anvendes for at sortere kronologisk for ÅrUge
	column ISOYear = ```
			YEAR ( [Date] - WEEKDAY([Date], 2) + 4 )
			
			```
		formatString: 0
		displayFolder: Sorteringskolonner
		lineageTag: 86fad04c-092b-44d5-9cb8-cb6910635f30
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Denne kolonne anvendes for at ÅrUge sorteres korrekt kronologisk fremfor alfabetisk
	column ÅrUgeSort_ISO = 'Calendar'[ISOYear] * 100 + WEEKNUM([Date],21)
		formatString: 0
		displayFolder: Sorteringskolonner
		lineageTag: 1c8160d7-ad2a-45e5-b208-6cfc264209e7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column ÅrUge_Default = ```
			
			VAR StartOfWeek =
			    TODAY() - WEEKDAY ( TODAY(), 2 ) + 1
			VAR EndOfWeek =
			    StartOfWeek + 6
			RETURN
			IF (
			    MAX ( 'Calendar'[Date] ) >= StartOfWeek
			        && MAX ( 'Calendar'[Date] ) <= EndOfWeek,
			    "Indeværende uge",
			    SELECTEDVALUE ( 'Calendar'[ÅrUge] )
			)
			
			```
		displayFolder: Filterformål
		lineageTag: fe786765-6a39-446b-ab36-9abe831a6cd5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

