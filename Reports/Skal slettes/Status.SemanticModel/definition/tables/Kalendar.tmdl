	partition Kalendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    CALENDAR (DATE(2024, 05, 01), DATE(2025, 12, 31)),
				    "Year", YEAR([Date]),
				    "Month", MONTH([Date]),
				    "Day", DAY([Date]),
				    "MonthName", FORMAT([Date], "MMMM"),
				    "Quarter", "Q" & FORMAT([Date], "Q")
				)
				
				```

