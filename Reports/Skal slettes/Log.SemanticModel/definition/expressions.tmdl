expression 'DirectQuery to AS - Status_modelV3' =
		let
		    Source = AnalysisServices.Database("powerbi://api.powerbi.com/v1.0/myorg/Reports", "Status_modelV3"),
		    Cubes = Table.Combine(Source[Data]),
		    Cube = Cubes{[Id="Model", Kind="Cube"]}[Data]
		in
		    Cube
	lineageTag: 073dadb7-be5e-4f31-b3ad-484762cc202b

	annotation PBI_IncludeFutureArtifacts = True

