		level FullDate
			lineageTag: d5f7b1c6-7c86-413a-946f-ef856a3b6b87
			column: FullDate

	partition Kalendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    CALENDAR (DATE(2024, 05, 01), DATE(2025, 12, 31)),
				    "Year", YEAR([Date]),
				    "Month", MONTH([Date]),
				    "Day", DAY([Date]),
				    "MonthName", FORMAT([Date], "MMMM"),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "FullDate", [Date]
				)
				
				```

	annotation PBI_Id = 085535af873e40ff8d3d3e137643db8d

